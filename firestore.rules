rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is a super admin
    function isSuperAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    // Categories are public read, admin write
    match /categories/{category} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    // Businesses
    match /businesses/{business} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.owner_id || isSuperAdmin());
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.user_id || 
         request.auth.uid == resource.data.business_owner_id || 
         isSuperAdmin());
    }

    // Services & Promotions
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
